#include<stdio.h>
#include<limits.h>
typedef struct{
char pid[10];
int at,bt,rt,ct,wt,tat;
}P;
void srtf(P p[], int n, float *avgwt, float *avgtat){
for(int i=0;i<n;i++)
p[i].rt=p[i].bt;
int done=0,t=0,idx,min;
float sumwt=0,sumtat=0;
while(done<n){
idx=-1;
min=INT_MAX;
for(int i=0;i<n;i++){
if(p[i].at<=t && p[i].rt>0 && p[i].rt<min){
min=p[i].rt;
idx=i;
}
}
if(idx==-1){
t++;
continue;
}
p[idx].rt--;
t++;
if(p[idx].rt==0){
done++;
p[idx].ct=t;
p[idx].tat=p[idx].ct-p[idx].at;
p[idx].wt=p[idx].tat-p[idx].bt;
if(p[idx].wt<0)
p[idx].wt=0;
sumwt+=p[idx].wt;
sumtat+=p[idx].tat;
}
}
*avgwt=sumwt/n;
*avgtat=sumtat/n;
}
int main(){
int n;
printf("Enter number of processes:\n");
scanf("%d"
,&n);
P p[n];
printf("Enter PID ArrivalTime BurstTime for each process:\n");
for(int i=0;i<n;i++){
scanf("%s%d%d"
,p[i].pid,&p[i].at,&p[i].bt);
}
float avgwt,avgtat;
srtf(p,n,&avgwt,&avgtat);
printf("\nWaiting Time:\n");
for(int i=0;i<n;i++){
printf("%s %d\n"
,p[i].pid,p[i].wt);
}
printf("\nTurnaround Time:\n");
for(int i=0;i<n;i++){
printf("%s %d\n"
,p[i].pid,p[i].tat);
}
printf("\nAverage Waiting Time: %.1f\n"
,avgwt);
printf("Average Turnaround Time: %.1f\n"
,avgtat);
return 0;
}
